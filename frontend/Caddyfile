# Caddy streže web portal in preusmerja /api na backend.
# DOMAIN pride iz okolja (docker-compose). HTTPS certifikat je samodejen (Let's Encrypt).
{$DOMAIN} {
	encode gzip

	# API + Swagger → NestJS backend
	handle /api/* {
		reverse_proxy backend:4000
	}

	# Beta prenos Android APK (test pri uporabnikih pred Google Play).
	# Datoteke iz host mape /downloads (glej docker-compose.prod.yml).
	# Stare različice beta strani so imele relativno povezavo, ki je padla na koren.
	redir /gasilapp.apk /beta/gasilapp.apk permanent
	handle_path /beta* {
		root * /downloads
		@apk path *.apk
		header @apk {
			Content-Type application/vnd.android.package-archive
			Content-Disposition "attachment; filename=gasilapp.apk"
			# APK vedno leži na ISTI poti (/beta/gasilapp.apk), zato brskalnik
			# brez tega postreže predpomnjeno staro različico — tester namesti
			# star build in misli, da objava ni delovala. "no-cache" ne pomeni
			# "ne shrani", ampak "pred uporabo vedno preveri": ob nespremenjeni
			# datoteki ETag vrne 304 in 75 MB se NE prenese znova.
			Cache-Control "no-cache"
		}
		# Beta stran se ne sme predpomniti — povezava/verzija se spreminjata.
		@html not path *.apk
		header @html Cache-Control "no-cache"
		file_server
	}

	# React SPA (statika + fallback na index.html za client-side routing)
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
