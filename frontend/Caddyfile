# Caddy streže web portal in preusmerja /api na backend.
# DOMAIN pride iz okolja (docker-compose). HTTPS certifikat je samodejen (Let's Encrypt).
{$DOMAIN} {
	encode gzip

	# API + Swagger → NestJS backend
	handle /api/* {
		reverse_proxy backend:4000
	}

	# Beta prenos Android APK (test pri uporabnikih pred Google Play).
	# Datoteke iz host mape /downloads (glej docker-compose.prod.yml).
	handle_path /beta* {
		root * /downloads
		@apk path *.apk
		header @apk {
			Content-Type application/vnd.android.package-archive
			Content-Disposition "attachment; filename=gasilapp.apk"
		}
		file_server
	}

	# React SPA (statika + fallback na index.html za client-side routing)
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
