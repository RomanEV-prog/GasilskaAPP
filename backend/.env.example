# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=gasilapp

# TypeORM
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT
JWT_SECRET=ZAMENJAJ_Z_DOLGIM_RANDOM_STRINGOM
# Dostopni žeton je kratkoživ, refresh žeton dolgoživ (rotacija ob /auth/refresh).
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=30d
# Če ni nastavljen, se izpelje iz JWT_SECRET (priporočeno: lasten random string).
JWT_REFRESH_SECRET=ZAMENJAJ_Z_DRUGIM_DOLGIM_RANDOM_STRINGOM

# File storage (MVP: lokalno; privzeto ./uploads)
# UPLOADS_DIR=C:\pot\do\uploads

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Firebase (za push obvestila)
FIREBASE_PROJECT_ID=gasilapp
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@gasilapp.iam.gserviceaccount.com
